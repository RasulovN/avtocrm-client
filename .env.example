# Namuna environment fayli.
# DEV uchun:  cp .env.example .env.development
# PROD uchun: cp .env.example .env.production
# Maxfiy kalitlarni .env.local yoki Vercel secrets'da saqlang.

# ===== Backend API manzili =====
# Dev (lokal backend):  http://localhost:8000/api
# Prod (deploy):         https://api.zumex.uz/api
# Yoki Vite proxy uchun: /api  (+ VITE_PROXY_TARGET ni o'rnating)
VITE_API_URL=https://api.zumex.uz/api

# ===== Media/rasm origin'i =====
# Dev:  http://localhost:8000   (proxy ishlatilsa bo'sh qoldiring)
# Prod: https://api.zumex.uz
VITE_MEDIA_ORIGIN=https://api.zumex.uz

# ===== Vite proxy target (faqat VITE_API_URL=/api proxy rejimida kerak) =====
VITE_PROXY_TARGET=https://api.zumex.uz

# ===== Yandex Maps API kaliti (Yandex panelida domen bo'yicha cheklang!) =====
VITE_YANDEX_MAPS_API_KEY=92688ac7-af1a-4e61-8646-1d9cc6cde872
